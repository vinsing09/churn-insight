# Database connection URL (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./data/churn.db

# Anthropic API key for Claude classification and brief generation
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key for text embeddings
OPENAI_API_KEY=sk-...

# Typeform OAuth app credentials
TYPEFORM_CLIENT_ID=your_typeform_client_id
TYPEFORM_CLIENT_SECRET=your_typeform_client_secret
TYPEFORM_REDIRECT_URI=http://localhost:8000/api/v1/integrations/typeform/callback

# Delighted API key (found in Settings > API)
DELIGHTED_API_KEY=your_delighted_api_key

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET_KEY=changeme_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
# Token expiry in minutes (10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Fernet encryption key for storing OAuth tokens — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# Stripe keys for billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend API key for transactional email
RESEND_API_KEY=re_...

# Frontend URL for CORS (update for production)
FRONTEND_URL=http://localhost:3000
